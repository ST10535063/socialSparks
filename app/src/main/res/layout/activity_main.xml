<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Social Sparks"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#3A5A80"
        android:layout_marginBottom="15dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Type in the time of day (like Morning or Dinner) to get a quick social idea!"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="30dp" />

    <EditText
        android:id="@+id/timeInputEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Time of Day (e.g., Afternoon)"
        android:inputType="text"
        android:padding="15dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/generateIdeaBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Spark an Idea"
        android:padding="12dp"
        android:backgroundTint="#7ABAE2"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/clearBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear"
        android:padding="12dp"
        android:backgroundTint="#A9B8C0"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/suggestionOutputView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textStyle="italic"
        android:textAlignment="center"
        android:textColor="#424242"
        android:padding="10dp"/>

</LinearLayout>